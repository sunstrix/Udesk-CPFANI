# Em todos os ambientes, os seguintes arquivos são carregados se existirem,
# onde os posteriores têm precedência sobre os anteriores:
#
#  * .env                contém valores padrão para as variáveis de ambiente necessárias pelo app
#  * .env.local          arquivo não versionado com substituições locais
#  * .env.$APP_ENV       padrões específicos do ambiente versionados
#  * .env.$APP_ENV.local substituições específicas do ambiente não versionadas
#
# Variáveis de ambiente reais do sistema sobrepõem os arquivos .env.
#
# NÃO DEFINA SEGREDOS DE PRODUÇÃO NESTE ARQUIVO NEM EM QUALQUER OUTRO ARQUIVO VERSIONADO.
#
# Execute "composer dump-env prod" para compilar arquivos .env para uso em produção (requer symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices/configuration.html#infrastructure-related-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=YOUR_APP_SECRET
APP_LOCALE=pt_BR
APP_DEFAULT_LOCALE=pt_BR
#TRUSTED_PROXIES=127.0.0.1,127.0.0.2
#TRUSTED_HOSTS='^localhost|example\.com$'
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Formato descrito em https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# Para um banco SQLite, use: "sqlite:///%kernel.project_dir%/var/data.db"
# Configure seu driver de banco e server_version em config/packages/doctrine.yaml
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
###< doctrine/doctrine-bundle ###

###> expiração de sessão ###
# Define o tempo de expiração da sessão em segundos.
UV_SESSION_COOKIE_LIFETIME=1440
###< expiração de sessão ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> google/recaptcha ###
# Para usar o Google Recaptcha, você deve registrar um site no painel de administração do Recaptcha:
# https://www.google.com/recaptcha/admin
GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_RECAPTCHA_SECRET=
###< google/recaptcha ###

###> symfony/swiftmailer-bundle ###
# Para Gmail como transporte, use: "gmail://usuario:senha@localhost"
# Para um servidor SMTP genérico, use: "smtp://localhost:25?encryption=&auth_mode="
# O envio está desativado por padrão via "null://localhost"
MAILER_URL=null://localhost
###< symfony/swiftmailer-bundle ###